# KadiRail AI - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# LINE OCR API (for document scanning)
# ============================================
# Get these from LINE Developers Console
# https://developers.line.biz/
#
# 1. Create a Messaging API channel
# 2. Go to "LINE Official Account Manager" > "Settings" > "Messaging API"
# 3. Create QR code for OCR (LIFF) or use Messaging API

LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_ACCESS_TOKEN=your_access_token

# ============================================
# Optional: Thai NLP Services
# ============================================
# PyThaiNLP is used by default (offline)
# Uncomment if you want to use cloud services

# THAI_NLP_PROVIDER=pythainlp  # default (offline)

# ============================================
# Development Settings
# ============================================
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# Demo Mode (uses mock data)
# ============================================
# Set to true to skip API keys and use sample data
DEMO_MODE=true
